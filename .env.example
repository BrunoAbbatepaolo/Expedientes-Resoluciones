APP_NAME="Servicio de Exp-Res"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Default DB connection ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# --- MySQL LEGUi ---
LEGUI_DB_HOST=127.0.0.1
LEGUI_DB_PORT=3306
LEGUI_DB_DATABASE=legui
LEGUI_DB_USERNAME=legui_user
LEGUI_DB_PASSWORD=
LEGUI_DB_CHARSET=utf8mb4
LEGUI_DB_COLLATION=utf8mb4_unicode_ci

# --- MySQL ADMIN ---
ADMIN_DB_HOST=127.0.0.1
ADMIN_DB_PORT=3306
ADMIN_DB_DATABASE=admin
ADMIN_DB_USERNAME=admin_user
ADMIN_DB_PASSWORD=
ADMIN_DB_CHARSET=utf8mb4
ADMIN_DB_COLLATION=utf8mb4_unicode_ci

# --- Postgres genérico ---
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=laravel
PG_USERNAME=postgres
PG_PASSWORD=
PG_CHARSET=utf8
PG_SEARCH_PATH=public
PG_SSLMODE=prefer

# --- Postgres MITIV ---
MITIV_PG_HOST=127.0.0.1
MITIV_PG_PORT=5432
MITIV_PG_DATABASE=mitivdb
MITIV_PG_USERNAME=postgres
MITIV_PG_PASSWORD=
MITIV_PG_CHARSET=utf8
MITIV_PG_SEARCH_PATH=public
MITIV_PG_SSLMODE=prefer

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
